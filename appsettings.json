{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "CloudinarySettings": {
    "CloudName": "YOUR_CLOUD_NAME",
    "ApiKey": "YOUR_API_KEY",
    "ApiSecret": "YOUR_API_SECRET"
  },
  "UploadSettings": {
    "AllowedExtensions": [ ".jpg", ".jpeg", ".png", ".webp" ],
    "MaxFileSizeInMB": 5
  }
}
